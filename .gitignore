# ============================================================
# FSA-Based Missionaries and Cannibals Puzzle Game
# Public GitHub repository ignore rules
# Python / Pygame / PyInstaller / Windows / temporary files
# ============================================================

# -----------------------------
# Python cache and bytecode
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# -----------------------------
# Python virtual environments
# -----------------------------
venv/
.venv/
ENV/
env/
original-pygame/venv/
original-pygame/.venv/

# -----------------------------
# Python packaging / installer outputs
# -----------------------------
pip-wheel-metadata/
*.egg-info/
.eggs/
build/
dist/
site/
*.manifest
*.spec

# -----------------------------
# PyInstaller build outputs
# Keep source code public, but do not commit generated binaries/cache.
# Recommended: publish Windows ZIP through GitHub Releases.
# -----------------------------
original-pygame/build/
original-pygame/dist/
original-pygame/*.spec
original-pygame/*.manifest

# -----------------------------
# Release archives / packaged binaries
# Uncomment the exception only if you intentionally want to version a small release ZIP.
# Recommended default: keep release ZIPs out of the main repository and upload to GitHub Releases.
# -----------------------------
release/*.zip
release/*.exe
release/*.msi
*.exe
*.msi
*.zip

# Keep placeholder files if needed
!release/.gitkeep

# -----------------------------
# Node / frontend dependencies and generated outputs
# -----------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------
# Environment variables and secrets
# -----------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_dsa
id_dsa.*
id_ed25519
id_ed25519.*
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
secrets.*
credentials.*
*credential*
*secret*
*password*

# -----------------------------
# Database dumps and local databases
# -----------------------------
*.sql
*.sqlite
*.sqlite3
*.db
*.dump
*.bak.sql

# -----------------------------
# Logs and temporary files
# -----------------------------
*.log
logs/
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*
.cache/
tmp/
temp/

# -----------------------------
# IDE/editor files
# -----------------------------
.vscode/
.idea/
*.code-workspace

# -----------------------------
# Windows / macOS / Linux system files
# -----------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride
._*
.Trashes
.fseventsd
.Spotlight-V100

# -----------------------------
# Pygame runtime / generated captures
# Keep curated demo screenshots in demo-assets/screenshots.
# -----------------------------
*.wav.tmp
*.mp3.tmp
original-pygame/screenshots/tmp/
original-pygame/screenshots/temp/
